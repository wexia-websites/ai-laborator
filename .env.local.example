# Supabase — získáš na supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TVUJ-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tvuj-anon-key
# Server-side write (cron AI Watch, admin operace). Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=tvuj-service-role-key

# Anthropic — pouze na serveru, uživatelé ho nevidí
# Získáš na console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — pouze na serveru, pro AI News feed přes Responses API + web_search
# gpt-5.4 = sweet spot ($2.5/M in, $15/M out, 1M context, knowledge cutoff Aug 2025)
# gpt-5.5 = ~2× cena, frontier pro complex reasoning (přepni jen pokud uvidíš kvalitativní regresi)
# gpt-5.4-mini = ~5× levnější ($0.75/$4.5), 400K context — vhodné pokud chceš ušetřit
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4

# AI Watch — denní cron běh /api/ai-watch/run
AI_WATCH_CRON_SECRET=change-me-long-random-string
AI_WATCH_STORE=supabase
AI_WATCH_SKIP_DAYS=90
# Volitelné: vlastní lokální cesta pro JSON store (jen pokud AI_WATCH_STORE=local)
# AI_WATCH_LOCAL_DATA_DIR=./data/ai-watch

# Langfuse — LLM observability (self-hosted lokálně, web UI na :3001)
# Vytvoř projekt v UI, zkopíruj klíče (Settings → API Keys)
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Make.com webhook — odesílání use casů po publishnutí
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/your-webhook-url
